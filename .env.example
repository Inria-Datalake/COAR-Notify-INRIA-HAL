# Environment configuration
# Copy to .env and adjust for your setup. When running under Docker Compose,
# the compose file sets ARANGO_HOST=arangodb automatically; for local runs use localhost.

ARANGO_HOST=localhost
ARANGO_PORT=8529
ARANGO_USERNAME=root
ARANGO_ROOT_PASSWORD=examplepassword
ARANGO_DB=COAR_NOTIFY_DB

FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# API token required in the `x-api-key` header for protected endpoints.
# Generate a strong value, e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`.
API_TOKEN=change-me

# Origin URL advertised to remote inboxes in outbound COAR notifications.
# Change this to your public-facing base URL (no trailing slash).
# COAR_ORIGIN_BASE_URL=https://prod-datadcis-api.inria.fr/coar

# HAL Configuration
# HAL_BASE_URL=https://inria.hal.science
# HAL_INBOX_URL=https://inbox-preprod.archives-ouvertes.fr/
# HAL_TOKEN=your_hal_token_here

# Software Heritage Configuration
# SWH_BASE_URL=https://archive.softwareheritage.org
# SWH_INBOX_URL=https://inbox.staging.swh.network/
# SWH_TOKEN=your_swh_token_here

# Software Viz
# SW_VIZ_URL=
# SW_VIZ_TOKEN=your_sw_viz_token_here
